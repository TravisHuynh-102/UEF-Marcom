# BẢO MẬT: Bất kỳ biến nào bắt đầu bằng NEXT_PUBLIC_ sẽ bị lộ ra trình duyệt. 
# Chỉ dùng NEXT_PUBLIC_ cho những dữ liệu công khai.
# Những biến KHÔNG có chữ NEXT_PUBLIC_ sẽ được giấu kín và chỉ chạy ngầm trên máy chủ.

# ==========================================
# 1. BẢO MẬT HỆ THỐNG
# ==========================================
# Khóa bí mật dùng để mã hóa thông tin người dùng (VD: JWT Token, Session)
# Bạn nên dùng một chuỗi mã hóa mạnh.
APP_SECRET_KEY="super_secret_key_change_in_production"

# ==========================================
# 2. KẾT NỐI DATABASE
# ==========================================
# Đường dẫn kết nối tới cơ sở dữ liệu (Database URL)
DATABASE_URL="postgresql://user:password@localhost:5432/marcom_db"

# ==========================================
# 3. KẾT NỐI BÊN THỨ 3 (API KEYS)
# ==========================================
# API Key để dùng tính năng AI (VD: OpenAI)
OPENAI_API_KEY="sk-..."

# ==========================================
# 4. THÔNG TIN URL
# ==========================================
# Đường dẫn chính của website (Công khai cho trình duyệt)
NEXT_PUBLIC_SITE_URL="https://marcom-uef.vercel.app"
